NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application base URL — used to build OAuth redirect URIs.
# Change to your production domain when deploying.
APP_BASE_URL=http://localhost:3000

# AES-256-GCM key for encrypting stored OAuth tokens.
# OPTIONAL — if not set, the key is automatically derived from SUPABASE_SERVICE_ROLE_KEY.
# Set this explicitly in production if you want a key independent of your Supabase project.
# Generate with: openssl rand -hex 32
# CREDENTIAL_ENCRYPTION_KEY=your_64_char_hex_key

# OpenRouter — AI reply generation
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_CLAUDE_MODEL=anthropic/claude-sonnet-4.6

# Google OAuth — system-level credentials for YouTube (SaaS mode).
# Self-hosted users can override these per-account from the Settings page.
# Create at: https://console.cloud. google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/v1/auth/youtube/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional: per-platform redirect URI overrides.
# Defaults to APP_BASE_URL + /api/v1/auth/<platform>/callback.
# YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/youtube/callback
# INSTAGRAM_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/instagram/callback
# FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/facebook/callback
# LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/auth/linkedin/callback
